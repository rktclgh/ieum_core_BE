# app-ai listens on 8081; app-main normally listens on 8080.
SERVER_PORT=8081

# Runtime mode: server | knowledge-import
APP_AI_MODE=server

# One shared Gemini API key for report review, embeddings, local answers, and web grounding.
APP_AI_GEMINI_API_KEY=

# DB
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ieum
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Report image evidence (required when APP_AI_FEATURES_REPORT_REVIEW_ENABLED=true)
APP_AI_FEATURES_REPORT_REVIEW_ENABLED=false
APP_AI_REPORT_IMAGE_ALLOWED_HOSTS=ieum.rktclgh.site,localhost,127.0.0.1
APP_AI_REPORT_IMAGE_MAX_BYTES=3750000
APP_AI_REPORT_IMAGE_MAX_TOTAL_BYTES=15000000
APP_AI_REPORT_IMAGE_DOWNLOAD_TIMEOUT=5s

# Question answer/accepted-answer workers and shared embeddings.
# The shared Gemini key is required when either feature is enabled or APP_AI_MODE=knowledge-import.
APP_AI_FEATURES_QUESTION_ANSWER_ENABLED=false
APP_AI_FEATURES_ACCEPTED_ANSWER_INGESTION_ENABLED=false
APP_AI_FEATURES_ACCEPTED_ANSWER_RELATION_CANDIDATES_ENABLED=false
APP_AI_FEATURES_WEB_GROUNDING_ENABLED=false
# Temporary fallback: create a marked ungrounded answer when local/web evidence is unavailable.
APP_AI_FEATURES_UNGROUNDED_ANSWER_ENABLED=false
APP_AI_QUESTION_EMBEDDING_MODEL_TIMEOUT=10s
APP_AI_QUESTION_EMBEDDING_TOTAL_ATTEMPTS=1
APP_AI_ACCEPTED_ANSWER_TASK_LEASE=5m
APP_AI_ACCEPTED_ANSWER_MAX_ATTEMPTS=5
APP_AI_ACCEPTED_ANSWER_REDISPATCH_DELAY_SECONDS=5
APP_AI_KNOWLEDGE_RELATION_RECOVERY_INTERVAL=30s
APP_AI_KNOWLEDGE_RELATION_RECOVERY_BATCH_SIZE=8
APP_AI_QUESTION_ANSWER_TASK_LEASE=2m
APP_AI_QUESTION_ANSWER_MAX_ATTEMPTS=5
APP_AI_QUESTION_ANSWER_DISPATCH_RETRY_AFTER_SECONDS=5
APP_AI_QUESTION_ANALYZER_MODEL=apac.amazon.nova-micro-v1:0
APP_AI_QUESTION_ANALYZER_ANALYSIS_VERSION=question-query-analysis-v1
APP_AI_QUESTION_ANALYZER_MAX_TOKENS=512
APP_AI_BEDROCK_REGION=ap-northeast-2
# Optional local named AWS profile. Leave empty to use the standard AWS credential chain.
APP_AI_BEDROCK_PROFILE=
APP_AI_BEDROCK_TIMEOUT=30s

# Local grounded answer: Nova Micro first, Gemini Flash-Lite once with Google Search/tools disabled.
APP_AI_QUESTION_GENERATION_NOVA_MODEL=apac.amazon.nova-micro-v1:0
APP_AI_QUESTION_GENERATION_GEMINI_MODEL=gemini-3.1-flash-lite
APP_AI_QUESTION_GENERATION_PROMPT_VERSION=question-local-answer-v1
APP_AI_QUESTION_GENERATION_MAX_TOKENS=1024
APP_AI_QUESTION_GENERATION_MODEL_TIMEOUT=30s

# Local answer grounding validation and one repair attempt. Providers reuse the generation models/key.
APP_AI_QUESTION_GROUNDING_VALIDATION_PROMPT_VERSION=question-grounding-validation-v1
APP_AI_QUESTION_GROUNDING_REPAIR_PROMPT_VERSION=question-grounding-repair-v1
APP_AI_QUESTION_GROUNDING_VALIDATION_MAX_TOKENS=512
APP_AI_QUESTION_GROUNDING_REPAIR_MAX_TOKENS=1024
APP_AI_QUESTION_GROUNDING_MODEL_TIMEOUT=30s

# Google Search grounding fallback.
APP_AI_QUESTION_WEB_GROUNDING_MODEL=gemini-3.1-flash-lite
APP_AI_QUESTION_WEB_GROUNDING_PROMPT_VERSION=question-web-grounding-v1
APP_AI_QUESTION_WEB_GROUNDING_MAX_TOKENS=1024
APP_AI_QUESTION_WEB_GROUNDING_MODEL_TIMEOUT=45s

# Gemini fallback without Google Search. Stored with answer_outcome=ungrounded and evidence=[].
APP_AI_QUESTION_UNGROUNDED_MODEL=gemini-3.1-flash-lite
APP_AI_QUESTION_UNGROUNDED_PROMPT_VERSION=question-ungrounded-answer-v1
APP_AI_QUESTION_UNGROUNDED_MAX_TOKENS=1024
APP_AI_QUESTION_UNGROUNDED_MODEL_TIMEOUT=30s

# app-ai(8081) -> app-main(8080) question completion callback.
# Keep this target on app-main; pointing it at app-ai would create a self-call misconfiguration.
APP_AI_QUESTION_CALLBACK_BASE_ORIGIN=http://localhost:8080
APP_AI_QUESTION_CALLBACK_ALLOWED_ORIGINS=http://localhost:8080
APP_AI_INTERNAL_CALLBACK_TOKEN=
APP_AI_QUESTION_CALLBACK_CONNECT_TIMEOUT=2s
APP_AI_QUESTION_CALLBACK_READ_TIMEOUT=5s

# Report AI providers (required when APP_AI_FEATURES_REPORT_REVIEW_ENABLED=true)
APP_AI_REPORT_GEMINI_MODEL=gemini-3.1-flash-lite
APP_AI_REPORT_NOVA_MODEL=apac.amazon.nova-lite-v1:0
APP_AI_REPORT_PROMPT_VERSION=report-review-v1
