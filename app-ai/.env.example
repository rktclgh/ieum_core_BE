# DB
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ieum
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Internal HMAC-SHA256 v1 (Base64-encoded shared secret; decoded length >= 32 bytes)
IEUM_INTERNAL_HMAC_SERVICE_NAME=app-main
IEUM_INTERNAL_HMAC_CURRENT_KEY_ID=
IEUM_INTERNAL_HMAC_CURRENT_SECRET_BASE64=
IEUM_INTERNAL_HMAC_PREVIOUS_KEY_ID=
IEUM_INTERNAL_HMAC_PREVIOUS_SECRET_BASE64=
IEUM_INTERNAL_HMAC_CLOCK_SKEW_SECONDS=60
IEUM_INTERNAL_HMAC_MAX_BODY_BYTES=1048576
IEUM_INTERNAL_HMAC_REPLAY_MAX_ENTRIES=10000
IEUM_INTERNAL_HMAC_REPLAY_TTL_SECONDS=120
