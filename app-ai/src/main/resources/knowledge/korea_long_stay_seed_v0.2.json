        {"subject": "NPS 자격 확인", "predicate": "prevents", "object": "출국만으로 자동 지급된다는 오인", "confidence": 0.96, "evidenceChunkOrder": 0}
      ]
    },
    {
      "sourceKey": "kr-nps-incheon-airport-refund",
      "displayName": "인천공항 국민연금 반환일시금 지급",
