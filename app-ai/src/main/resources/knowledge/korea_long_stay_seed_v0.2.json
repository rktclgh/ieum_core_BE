      "canonicalUrl": "https://www.gov.kr/mw/AA020InfoCappView.do?CappBizCD=12700000025&HighCtgCD=A01010&tp_seq=",
      "supportingUrls": ["https://moj.go.kr/bbs/moj/93/559234/artclView.do"],
      "contentHash": "4f956cabefa62da27f6efb5f6294892bff14f98b2956da7ae52fe90ec1b0c1f5",
      "chunks": [{"chunkOrder": 0, "text": "상황: 한국에 입국해 90일을 초과하여 체류할 예정입니다. 규칙: 원칙적으로 입국일부터 90일 이내에 체류지 관할 출입국·외국인관서에 외국인등록을 신청합니다. 하이코리아 방문예약 후 여권, 체류지 입증서류, 최근 여권용 사진과 체류자격별 서류를 준비합니다. 방지할 실수: 체류기간 90일과 등록기한 90일을 혼동해 신청을 늦추거나, 관할이 아닌 기관을 방문하지 마세요."}],
      "relations": [
        {"subject": "90일 초과 체류 예정 외국인", "predicate": "requires", "object": "외국인등록", "confidence": 0.99, "evidenceChunkOrder": 0},
        {"subject": "외국인등록", "predicate": "has_deadline", "object": "입국일부터 90일 이내", "confidence": 0.99, "evidenceChunkOrder": 0},
        {"subject": "외국인등록", "predicate": "reported_to", "object": "체류지 관할 출입국·외국인관서", "confidence": 0.99, "evidenceChunkOrder": 0}
      ]
    },
    {
      "sourceKey": "kr-residence-change-report-15-days",
      "displayName": "등록외국인 체류지 변경 신고",
      "documentType": "knowledge_tip",
      "answerEligible": true,
      "sourceGrade": "government",
      "authorityLevel": "national",
      "jurisdiction": {"country": "KR"},
      "geoScope": "general",
      "regionContext": {},
