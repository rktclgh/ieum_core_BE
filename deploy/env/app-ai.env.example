# Copy the completed file into the GitHub Environment secret APP_AI_ENV_FILE.
# Never commit real credentials.

SERVER_PORT=8081
APP_AI_BIND_ADDRESS=172.31.33.42

SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR_DATABASE_HOST:5432/ieum
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
SPRING_AI_MODEL_CHAT=bedrock-converse

APP_AI_FEATURES_REPORT_REVIEW_ENABLED=false
APP_AI_FEATURES_QUESTION_ANSWER_ENABLED=false
APP_AI_FEATURES_WEB_GROUNDING_ENABLED=false

# One shared Gemini API key for report review, embeddings, local answers, and web grounding.
APP_AI_GEMINI_API_KEY=

APP_AI_REPORT_IMAGE_ALLOWED_HOSTS=ieum.rktclgh.site
APP_AI_REPORT_IMAGE_MAX_BYTES=3750000
APP_AI_REPORT_IMAGE_MAX_TOTAL_BYTES=15000000
APP_AI_REPORT_IMAGE_DOWNLOAD_TIMEOUT=5s
APP_AI_REPORT_GEMINI_MODEL=gemini-3.1-flash-lite
APP_AI_REPORT_NOVA_MODEL=amazon.nova-lite-v1:0
APP_AI_REPORT_PROMPT_VERSION=report-review-v1

APP_AI_QUESTION_EMBEDDING_MODEL_TIMEOUT=10s
APP_AI_QUESTION_EMBEDDING_TOTAL_ATTEMPTS=1
APP_AI_QUESTION_ANSWER_TASK_LEASE=2m
APP_AI_QUESTION_ANSWER_MAX_ATTEMPTS=5
APP_AI_QUESTION_ANSWER_RECOVERY_INTERVAL=60s
APP_AI_QUESTION_ANSWER_RECOVERY_BATCH_SIZE=32
APP_AI_QUESTION_ANSWER_DISPATCH_RETRY_AFTER_SECONDS=5
APP_AI_QUESTION_ANALYZER_MODEL=amazon.nova-micro-v1:0
APP_AI_QUESTION_ANALYZER_ANALYSIS_VERSION=question-query-analysis-v1
APP_AI_QUESTION_ANALYZER_MAX_TOKENS=512
APP_AI_BEDROCK_REGION=ap-southeast-2
APP_AI_BEDROCK_TIMEOUT=30s

APP_AI_QUESTION_GENERATION_NOVA_MODEL=amazon.nova-micro-v1:0
APP_AI_QUESTION_GENERATION_GEMINI_MODEL=gemini-3.1-flash-lite
APP_AI_QUESTION_GENERATION_PROMPT_VERSION=question-local-answer-v1
APP_AI_QUESTION_GENERATION_MAX_TOKENS=1024
APP_AI_QUESTION_GENERATION_MODEL_TIMEOUT=30s

APP_AI_QUESTION_GROUNDING_VALIDATION_PROMPT_VERSION=question-grounding-validation-v1
APP_AI_QUESTION_GROUNDING_REPAIR_PROMPT_VERSION=question-grounding-repair-v1
APP_AI_QUESTION_GROUNDING_VALIDATION_MAX_TOKENS=512
APP_AI_QUESTION_GROUNDING_REPAIR_MAX_TOKENS=1024
APP_AI_QUESTION_GROUNDING_MODEL_TIMEOUT=30s

APP_AI_QUESTION_CALLBACK_BASE_ORIGIN=http://172.31.38.97:8080
APP_AI_QUESTION_CALLBACK_ALLOWED_ORIGINS=http://172.31.38.97:8080
APP_AI_QUESTION_CALLBACK_CONNECT_TIMEOUT=2s
APP_AI_QUESTION_CALLBACK_READ_TIMEOUT=5s
APP_AI_QUESTION_CALLBACK_RECOVERY_INTERVAL=60s

# Use exactly the same random value in app-main.
APP_AI_INTERNAL_CALLBACK_TOKEN=
