# Copy the completed file into the GitHub Environment secret APP_MAIN_ENV_FILE.
# Never commit real credentials.

SERVER_PORT=8080
SERVER_FORWARD_HEADERS_STRATEGY=native
APP_MAIN_PRIVATE_BIND_ADDRESS=172.31.38.97

SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR_DATABASE_HOST:5432/ieum
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

REDIS_HOST=host.docker.internal
REDIS_PORT=6379

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
INQUIRY_ADMIN_EMAIL=

JWT_SECRET=
EMAIL_VERIFICATION_HMAC_SECRET=
JWT_ACCESS_TOKEN_TTL_MINUTES=30
JWT_REFRESH_TOKEN_TTL_DAYS=14
COOKIE_SECURE=true
COOKIE_SAME_SITE=Lax
COOKIE_DOMAIN=
CORS_ALLOWED_ORIGINS=https://ieum.rktclgh.site

WEB_PUSH_ENABLED=false
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=
WEB_PUSH_ALLOWED_ENDPOINT_HOSTS=fcm.googleapis.com,push.services.mozilla.com,web.push.apple.com,notify.windows.com
WEB_PUSH_CONNECT_TIMEOUT=2s
WEB_PUSH_REQUEST_TIMEOUT=5s
WEB_PUSH_EXECUTOR_THREADS=2
WEB_PUSH_EXECUTOR_QUEUE=128
WEB_PUSH_EXECUTOR_SHUTDOWN_SECONDS=10

GOOGLE_CLIENT_ID=
GOOGLE_JWK_SET_URI=https://www.googleapis.com/oauth2/v3/certs
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URIS=https://ieum.rktclgh.site/oauth/kakao/callback/
KAKAO_TOKEN_URI=https://kauth.kakao.com/oauth/token
KAKAO_JWK_SET_URI=https://kauth.kakao.com/.well-known/jwks.json

NAVER_SEARCH_BASE_URL=https://openapi.naver.com
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
NCP_MAPS_BASE_URL=https://maps.apigw.ntruss.com
NCP_MAPS_KEY_ID=
NCP_MAPS_KEY=
PLACE_CONNECT_TIMEOUT_MS=2000
PLACE_READ_TIMEOUT_MS=3000
PLACE_MAX_CONCURRENT=20

AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_S3_BUCKET=
AWS_S3_API_CALL_TIMEOUT_SECONDS=10
AWS_S3_API_CALL_ATTEMPT_TIMEOUT_SECONDS=3
APP_FILE_S3_TMP_PREFIX=tmp
APP_FILE_S3_FINAL_PREFIX=final
APP_FILE_PRESIGN_TTL_MINUTES=15
APP_FILE_MAX_SIZE_BYTES=10485760
APP_FILE_DISPLAY_MAX_PX=1280
APP_FILE_THUMB_MAX_PX=320
APP_FILE_WEBP_QUALITY=80

APP_AI_REPORT_ENABLED=false
APP_AI_REPORT_BASE_URL=http://172.31.33.42:8081
APP_AI_REPORT_ALLOWED_HOSTS=172.31.33.42
APP_AI_REPORT_CONNECT_TIMEOUT_SECONDS=2
APP_AI_REPORT_READ_TIMEOUT_SECONDS=90

APP_AI_QUESTION_ANSWER_DISPATCH_ENABLED=false
APP_AI_QUESTION_ANSWER_DISPATCH_BASE_URL=http://172.31.33.42:8081
APP_AI_QUESTION_ANSWER_DISPATCH_ALLOWED_HOSTS=172.31.33.42
APP_AI_QUESTION_ANSWER_DISPATCH_CONNECT_TIMEOUT_SECONDS=2
APP_AI_QUESTION_ANSWER_DISPATCH_READ_TIMEOUT_SECONDS=5

# Use exactly the same random value in app-ai.
APP_AI_INTERNAL_CALLBACK_TOKEN=
