# Copy this file manually to $DEPLOY_PATH/.migration.env on each production EC2 host.
# Keep it owned by the SSH deployment user and set mode 600.
PGHOST=YOUR_PRIVATE_DATABASE_HOST
PGPORT=5432
PGDATABASE=ieum
PGUSER=YOUR_MIGRATION_USER

# Use PGPASSWORD or comment it out and configure an absolute PGPASSFILE path.
PGPASSWORD=REPLACE_WITH_THE_MIGRATION_PASSWORD
# PGPASSFILE=/home/ubuntu/.pgpass
